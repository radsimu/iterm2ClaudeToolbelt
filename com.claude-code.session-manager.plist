<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.claude-code.session-manager</string>

    <key>ProgramArguments</key>
    <array>
        <string>/Users/radu.simionescu/.pyenv/versions/3.14.0/bin/python3</string>
        <string>/Users/radu.simionescu/work/iterm2ClaudeToolbelt/claude_sessions.py</string>
    </array>

    <key>KeepAlive</key>
    <true/>

    <key>RunAtLoad</key>
    <true/>

    <key>StandardOutPath</key>
    <string>/tmp/claude-sessions.log</string>

    <key>StandardErrorPath</key>
    <string>/tmp/claude-sessions.log</string>

    <!-- Give iTerm2 time to start before the first connection attempt -->
    <key>ThrottleInterval</key>
    <integer>10</integer>
</dict>
</plist>
